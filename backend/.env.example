SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# JWT lifetimes
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# CORS (comma-separated origins for your frontend)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# CORS_ALLOW_ALL_ORIGINS=True

# Set USE_POSTGRES=True to use PostgreSQL; otherwise SQLite is used for local dev.
USE_POSTGRES=False
DB_NAME=team_task_manager
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432
